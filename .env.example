# Runtime
HOST=127.0.0.1
PORT=3010
NITRO_PORT=3010
DB_PATH=/root/work/anime-guess-ai/data/anime-guess.sqlite

# Bangumi
BANGUMI_TOKEN=
BANGUMI_USER_AGENT=anime-guess-ai/0.1 (https://github.com/nepsyn/anime-guess-ai)
SUBJECT_CACHE_TTL_MS=604800000

# AI provider: gpt 或 gemini
AI_PROVIDER=gpt

# GPT / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
